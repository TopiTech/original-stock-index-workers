{
  "name": "original-stock-index",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.worker.json --noEmit && vite build",
    "preview": "vite preview",
    "dev:worker": "wrangler dev --config wrangler.local.jsonc",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 execute original-stock-index-db --remote --config wrangler.local.jsonc --file=schema.sql",
    "db:seed": "wrangler d1 execute original-stock-index-db --remote --config wrangler.local.jsonc --file=seed.sql",
    "typegen": "wrangler types"
  },
  "dependencies": {
    "framer-motion": "^12.10.5",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.13.2"
  }
}
